// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Books uploaded by the user
model Book {
  id          String    @id @default(cuid())
  title       String
  author      String?
  filePath    String    // relative path to stored file
  fileType    String    // pdf, epub, mobi, txt
  fileSize    Int       // bytes
  uploadedAt  DateTime  @default(now())
  processedAt DateTime?

  chunks      BookChunk[]

  @@map("books")
}

// Extracted and embedded text chunks from books
model BookChunk {
  id           String   @id @default(cuid())
  bookId       String
  chapter      String?  // section/chapter name
  section      String?  // subsection name
  pageNumber   Int?
  contentType  String   // plant | pest | disease | composting | tip | task | general
  contentText  String   // the actual text content
  tokenCount   Int?
  createdAt    DateTime @default(now())

  book         Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  embeddings   ChunkEmbedding[]

  @@index([bookId])
  @@index([contentType])
  @@map("book_chunks")
}

// Vector embeddings for each chunk (stored as pgvector Float[])
model ChunkEmbedding {
  id         String   @id @default(cuid())
  chunkId    String
  model      String   // e.g. "llama3.2:3b"
  dimension  Int
  vector     Float[]  // pgvector: cosine similarity via <=> operator

  chunk      BookChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@unique([chunkId, model])
  @@map("chunk_embeddings")
}

// Structured plant entries — rich gardening knowledge base
model PlantEntry {
  id                  String    @id @default(cuid())
  bookId              String?
  commonName           String
  scientificName       String?
  variety              String?
  family               String?
  description          String?
  // Taxonomy & Category
  category             String?   // vegetable | fruit | herb | flower | tree | nut | legume
  // Growing Conditions
  sunlight             String?   // full sun | partial shade | shade
  waterNeeds           String?   // low | moderate | high | consistent
  soilType             String?   // sandy | loamy | clay | chalky | well-draining
  soilPh               String?   // e.g. "6.0-7.0"
  // Hardiness
  zoneMin              Int?
  zoneMax              Int?
  frostTolerance       String?   // none | light | moderate | hardy
  // Planting Details
  plantingDepth        String?   // e.g. "1/4 inch", "2-3 feet deep"
  spacing              String?   // e.g. "18-24 inches"
  daysToGermination    Int?
  daysToMaturity       Int?
  // Structure
  matureHeight         String?   // e.g. "6-8 feet"
  matureSpread         String?   // e.g. "3-4 feet"
  growthHabit          String?   // bush | vine | trailing | upright | rosette
  perennialYears       Int?      // null = annual
  // Companions & Pests
  companionPlants      Json?     // string[] of plant names
  incompatiblePlants   Json?     // string[] of plant names
  commonPests          Json?     // string[] of pest names
  commonDiseases       Json?     // string[] of disease names
  // Harvest
  harvestWindow        String?   // e.g. "June-October"
  harvestIndicators    String?   // e.g. "firm skin, full color"
  // Notes
  careNotes            String?
  // Timestamps
  createdAt            DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt

  @@index([category])
  @@index([scientificName])
  @@map("plant_entries")
}

// User accounts
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hashed
  createdAt DateTime @default(now())

  @@map("users")
}
